# Vertex AI Configuration
VERTEX_PROJECT_ID=your-project-id-here
VERTEX_LOCATION=us-central1
VERTEX_MODEL_NAME=gemini-1.5-pro

# Authentication (Option A: Private Key File - Recommended for Teams)
# 1. Place your service-account-key.json in the root folder
# 2. Set the path below:
GOOGLE_APPLICATION_CREDENTIALS=service-account-key.json

# Authentication (Option B: Individual Login)
# Only use this if GOOGLE_APPLICATION_CREDENTIALS is empty
# Run 'gcloud auth application-default login' in your terminal